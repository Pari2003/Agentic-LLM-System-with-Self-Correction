# ═══════════════════════════════════════════════════════
# Agentic LLM System with Self-Correction
# Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# ─── Ollama Configuration ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
TEXT_MODEL=llama3.2
EMBED_MODEL=nomic-embed-text
VISION_MODEL=moondream
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=3

# ─── Semantic Chunking ────────────────────────────────
CHILD_CHUNK_MIN_TOKENS=100
CHILD_CHUNK_MAX_TOKENS=512
PARENT_CHUNK_MAX_TOKENS=1024
CHUNK_OVERLAP_TOKENS=50
SEMANTIC_SPLIT_PERCENTILE=25

# ─── Retrieval Pipeline ──────────────────────────────
HYBRID_SEARCH_TOP_K=20
PARENT_EXPANSION_TOP_K=10
LLM_RERANK_TOP_K=5
RRF_K=60
GRAPH_BOOST_WEIGHT=0.02

# ─── Self-Correction ─────────────────────────────────
CONFIDENCE_THRESHOLD=0.7
MAX_CORRECTION_ITERATIONS=2
EMBEDDING_SIM_THRESHOLD=0.65

# ─── Session Management ──────────────────────────────
SESSION_TTL_HOURS=24
CLEANUP_INTERVAL_MINUTES=60

# ─── Storage Paths ────────────────────────────────────
CHROMADB_PATH=./data/chromadb
SQLITE_PATH=./data/metadata.db
PAPERS_DIR=./data/papers

# ─── API Server ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# ─── Embedding ────────────────────────────────────────
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=32
